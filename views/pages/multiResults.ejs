<%
// ✅ INITIALIZE ALL VARIABLES WITH SAFE DEFAULTS
searchQuery = searchQuery || '';
pagination = pagination || { page: 1, limit: 20, totalCount: 0, totalPages: 1, hasNextPage: false, hasPrevPage: false, nextPage: null, prevPage: null, startIndex: 0, endIndex: 0 };
results = results || [];
screeningId = screeningId || '';
statistics = statistics || { totalCandidates: 0, qualifiedCandidates: 0, averageBestScore: 0 };
jobCategories = jobCategories || [];
%>

<div class="container-fluid py-4">
  <!-- Header Section -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h1 class="h3 mb-1 text-white">
            <i class="fas fa-layer-group text-primary"></i>
            Multi-JD Screening Results
          </h1>
          <p class="text-light mb-0">
            Comprehensive candidate matching across multiple job categories
          </p>
        </div>
        <div class="text-end">
          <a href="/screening" class="btn btn-outline-light">
            <i class="fas fa-plus"></i> New Screening
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Enhanced Statistics Summary -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0 shadow-lg multi-stats-card">
        <div class="card-body text-white text-center py-4">
          <div class="row">
            <div class="col-md-3">
              <i class="fas fa-users fa-2x mb-2 text-info"></i>
              <h2 class="display-6 mb-1 text-white fw-bold">
                <% if (statistics && statistics.totalCandidates) { %> <%=
                statistics.totalCandidates %> <% } else { %> 0 <% } %>
              </h2>
              <p class="mb-0 text-light">Total Candidates Found</p>
            </div>
            <div class="col-md-3">
              <i class="fas fa-trophy fa-2x mb-2 text-warning"></i>
              <h2 class="display-6 mb-1 text-white fw-bold">
                <% if (statistics && (statistics.averageBestScore ||
                statistics.averageScore)) { %> <%=
                Math.round(statistics.averageBestScore ||
                statistics.averageScore || 0) %>% <% } else { %> 0% <% } %>
              </h2>
              <p class="mb-0 text-light">Average Best Match Score</p>
            </div>
            <div class="col-md-3">
              <i class="fas fa-briefcase fa-2x mb-2 text-success"></i>
              <h2 class="display-6 mb-1 text-white fw-bold">
                <% if (jobCategories && jobCategories.length) { %> <%=
                jobCategories.length %> <% } else if (statistics &&
                statistics.categoryBreakdown) { %> <%=
                statistics.categoryBreakdown.length %> <% } else { %> 4 <% } %>
              </h2>
              <p class="mb-0 text-light">Job Categories Screened</p>
            </div>
            <div class="col-md-3">
              <i class="fas fa-check-circle fa-2x mb-2 text-success"></i>
              <h2 class="display-6 mb-1 text-white fw-bold">
                <% if (statistics && statistics.qualifiedCandidates) { %> <%=
                statistics.qualifiedCandidates %> <% } else { %> 0 <% } %>
              </h2>
              <p class="mb-0 text-light">Qualified Candidates</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Export Results Section -->
  <% if (results && results.length > 0) { %>
  <div class="row mb-4">
    <div class="col-12">
      <div class="export-section-simple">
        <h5 class="export-title">
          <i class="fas fa-download me-2"></i>
          Export Results
        </h5>
        <a
          href="/screening/multi-results/<%= screeningId %>/export"
          class="btn-export-simple"
          id="exportButton"
        >
          <i class="fas fa-file-excel me-2"></i>
          DOWNLOAD EXCEL REPORT
          <small class="d-block mt-1">
            Export <% if (searchQuery) { %>filtered (<%= (pagination && pagination.totalCount) || 0 %> found)<% } %> candidates to spreadsheet
          </small>
        </a>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Search Bar Section -->
  <% if (results && results.length > 0) { %>
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0 shadow-lg search-card-modern">
        <div class="card-body">
          <form method="GET" action="" class="row g-3 align-items-center" id="searchForm">
            <div class="col-md-7">
              <label for="searchInput" class="form-label text-white fw-bold">
                <i class="fas fa-search me-2"></i>Search Candidates by Name or Email
              </label>
              <div class="input-group input-group-lg">
                <span class="input-group-text bg-dark text-white border-secondary">
                  <i class="fas fa-user-search"></i>
                </span>
                <input
                  type="text"
                  class="form-control bg-dark text-white border-secondary"
                  name="search"
                  id="searchInput"
                  value="<%= searchQuery || '' %>"
                  placeholder="Type candidate name or email to search..."
                  autocomplete="off"
                />
                <% if (searchQuery) { %>
                <a href="<%= '/screening/multi-results/' + screeningId %>" class="btn btn-outline-secondary" title="Clear search">
                  <i class="fas fa-times"></i>
                </a>
                <% } %>
              </div>
            </div>
            <div class="col-md-3">
              <label for="limitSelect" class="form-label text-white fw-bold">
                <i class="fas fa-list me-2"></i>Results Per Page
              </label>
              <select name="limit" id="limitSelect" class="form-select form-select-lg bg-dark text-white border-secondary" onchange="this.form.submit()">
                <option value="20" <%= (pagination && pagination.limit === 20) ? 'selected' : '' %>>20 per page</option>
                <option value="50" <%= (pagination && pagination.limit === 50) ? 'selected' : '' %>>50 per page</option>
                <option value="100" <%= (pagination && pagination.limit === 100) ? 'selected' : '' %>>100 per page</option>
              </select>
            </div>
            <div class="col-md-2" style="padding-top: 2rem;">
              <button type="submit" class="btn btn-primary btn-lg w-100 btn-modern">
                <i class="fas fa-search me-1"></i> Search
              </button>
            </div>
          </form>

          <!-- Search Results Info -->
          <% if (searchQuery) { %>
          <div class="alert alert-info mt-3 mb-0">
            <i class="fas fa-info-circle me-2"></i>
            Found <strong><%= (pagination && pagination.totalCount) || 0 %></strong> candidate<%= (pagination && pagination.totalCount) !== 1 ? 's' : '' %> matching "<strong><%= searchQuery %></strong>"
            <a href="<%= '/screening/multi-results/' + screeningId %>" class="alert-link ms-2">
              <i class="fas fa-times-circle"></i> Clear Search
            </a>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Global Filter Controls -->
  <% if (results && results.length > 0) { %>
  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0 shadow-lg filter-card-multi">
        <div class="card-body">
          <h5 class="card-title mb-3 text-white fw-bold">
            <i class="fas fa-filter text-primary"></i>
            Filter & Sort Candidates
          </h5>
          <div class="row align-items-center">
            <div class="col-md-4">
              <label for="minMatchScore" class="form-label text-white fw-bold">
                <i class="fas fa-sliders-h me-2"></i>Filter by minimum match
                score:
              </label>
              <input
                type="range"
                class="form-range"
                id="minMatchScore"
                min="0"
                max="100"
                value="0"
              />
              <small class="text-light">
                Score:
                <span id="scoreDisplay" class="fw-bold text-warning">0</span>%
              </small>
            </div>
            <div class="col-md-4">
              <label for="sortResults" class="form-label text-white fw-bold">
                <i class="fas fa-sort me-2"></i>Sort by:
              </label>
              <select
                class="form-select bg-dark text-white border-secondary"
                id="sortResults"
              >
                <option value="score-desc">Match Score (High to Low)</option>
                <option value="score-asc">Match Score (Low to High)</option>
                <option value="name-asc">Name (A-Z)</option>
                <option value="name-desc">Name (Z-A)</option>
                <option value="category">Group by Best Job Category</option>
              </select>
            </div>
            <div class="col-md-4">
              <label for="categoryFilter" class="form-label text-white fw-bold">
                <i class="fas fa-briefcase me-2"></i>Filter by Job Category:
              </label>
              <select
                class="form-select bg-dark text-white border-secondary"
                id="categoryFilter"
              >
                <option value="">All Categories</option>
                <option value="network_engineer">Network Engineer</option>
                <option value="full_stack_developer">
                  Full Stack Developer
                </option>
                <option value="software_developer">Software Developer</option>
                <option value="finance_intern">Finance Intern</option>
                <option value="general">General</option>
              </select>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Candidates Display -->
  <div class="row">
    <div class="col-12">
      <!-- Results Summary -->
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0 text-white fw-bold">
          <i class="fas fa-users text-primary"></i>
          All Candidates
        </h4>
        <div class="text-light">
          Showing
          <strong class="text-warning">
            <span id="visibleCount"><%= results.length %></span>
          </strong>
          of
          <strong class="text-white"><%= (pagination && pagination.totalCount) || 0 %></strong>
          candidates
          <% if (pagination && pagination.totalCount > results.length) { %>
          (Page <%= pagination.page %> of <%= pagination.totalPages %>)
          <% } %>
        </div>
      </div>

      <!-- Accordion Table Header (outside sortable container so sort doesn't move it) -->
      <div class="acc-thead">
        <div class="acc-th" style="width:55px;flex:none">Rank</div>
        <div class="acc-th acc-th-grow">Candidate</div>
        <div class="acc-th" style="width:90px;flex:none">Score</div>
        <div class="acc-th" style="width:180px;flex:none">Best Job</div>
        <div class="acc-th acc-th-exp" style="width:72px;flex:none">Exp</div>
        <div class="acc-th acc-th-skills">Top Skills</div>
        <div class="acc-th" style="width:122px;flex:none;text-align:right">Actions</div>
      </div>

      <!-- Sortable rows (direct children = acc-rows only) -->
      <div id="candidatesContainer">
        <% results.forEach(function(candidate, index) { %>
        <%
          var candidateName = candidate.candidateName || 'Unknown Candidate';
          if (candidate.resumeId && candidate.resumeId.candidateName) { candidateName = candidate.resumeId.candidateName; }
          var email = candidate.email || '';
          if (candidate.resumeId && candidate.resumeId.email) { email = candidate.resumeId.email; }
          var phone = candidate.phone || '';
          if (candidate.resumeId && candidate.resumeId.phone) { phone = candidate.resumeId.phone; }
          var bestJob = candidate.bestJobMatch || candidate.bestJob || {};
          var matchScore = bestJob.score || candidate.matchScore || 0;
          var jobCategory = bestJob.category || bestJob.jobTitle || 'general';
          var skills = candidate.skills || [];
          if (candidate.resumeId && candidate.resumeId.skills) { skills = candidate.resumeId.skills; }
          var experience = candidate.experienceYears || 0;
          if (candidate.resumeId && candidate.resumeId.experience && candidate.resumeId.experience.years) { experience = candidate.resumeId.experience.years; }
          var resumeId = candidate._id;
          if (candidate.resumeId && candidate.resumeId._id) { resumeId = candidate.resumeId._id; }
          else if (candidate.resumeId) { resumeId = candidate.resumeId; }
          var initials = candidateName.split(' ').filter(Boolean).map(function(w){return w[0]||'';}).join('').toUpperCase().slice(0,2) || '?';
          var scoreClass = matchScore >= 75 ? 'score-high' : matchScore >= 50 ? 'score-mid' : 'score-low';

          // Use global rank (works correctly across pagination pages)
          var globalRank = (pagination && pagination.startIndex) ? (pagination.startIndex + index) : (index + 1);
          var rankClass  = globalRank === 1 ? 'rank-gold' : globalRank === 2 ? 'rank-silver' : globalRank === 3 ? 'rank-bronze' : 'rank-normal';
          var avatarGrad = globalRank === 1 ? 'linear-gradient(135deg,#ffd700,#e67e00)' :
                           globalRank === 2 ? 'linear-gradient(135deg,#b0bec5,#78909c)' :
                           globalRank === 3 ? 'linear-gradient(135deg,#cd7f32,#8d5524)' :
                                              'linear-gradient(135deg,#6366f1,#8b5cf6)';

          var catKey = jobCategory.toLowerCase().replace(/[\s_]+/g,'');
          var jobDisplayTitle = (bestJob.jobTitle || jobCategory).replace(/_/g,' ').replace(/\b\w/g, function(l){return l.toUpperCase();});
          // Shorten long job titles so they fit in the pill without truncating
          var JOB_SHORT = {
            'Software Development Intern': 'Software Dev Intern',
            'Software Development': 'Software Dev',
            'Full Stack Developer': 'Full Stack Dev',
            'Network Engineer': 'Network Eng',
          };
          var jobDisplayShort = JOB_SHORT[jobDisplayTitle] || jobDisplayTitle;
          // Tooltip listing skills beyond the first 3
          var extraSkillsTitle = skills.length > 3 ? skills.slice(3).join(', ') : '';
        %>

        <div class="acc-row candidate-result-card"
             data-score="<%= matchScore %>"
             data-category="<%= jobCategory.toLowerCase().replace(/\s+/g,'_') %>"
             data-name="<%= candidateName.toLowerCase() %>"
             id="row-<%= index %>">

          <!-- Main row (always visible) -->
          <div class="acc-row-main" data-row-idx="<%= index %>" onclick="toggleAccRow(+this.dataset.rowIdx)">

            <div class="acc-cell" style="width:58px;flex:none">
              <div class="rank-badge <%= rankClass %>">#<%= globalRank %></div>
            </div>

            <!-- Candidate name + email preview -->
            <div class="acc-cell acc-cell-candidate">
              <div class="cand-avatar" data-grad="<%= avatarGrad %>"><%= initials %></div>
              <div class="cand-info">
                <div class="cand-name"><%= candidateName %></div>
                <% if (email) { %><div class="cand-email-preview"><%= email %></div><% } %>
              </div>
            </div>

            <!-- Match score -->
            <div class="acc-cell" style="width:90px;flex:none">
              <span class="score-pill <%= scoreClass %>"><%= Math.round(matchScore) %>%</span>
            </div>

            <div class="acc-cell" style="width:185px;flex:none">
              <span class="job-pill job-pill-<%= catKey %>" title="<%= jobDisplayTitle %>"><%= jobDisplayShort %></span>
            </div>

            <!-- Experience -->
            <div class="acc-cell acc-cell-exp" style="width:72px;flex:none">
              <% if (experience > 0) { %>
              <span class="exp-badge"><%= experience %>yr<%= experience !== 1 ? 's' : '' %></span>
              <% } else { %>
              <span class="exp-badge exp-fresher">Fresher</span>
              <% } %>
            </div>

            <!-- Top skills preview -->
            <div class="acc-cell acc-cell-skills">
              <div class="skills-preview">
                <% skills.slice(0,3).forEach(function(sk){ %><span class="skill-chip"><%= sk %></span><% }); %>
                <% if (skills.length > 3) { %><span class="skill-more" title="<%= extraSkillsTitle %>">+<%= skills.length - 3 %> more</span><% } %>
              </div>
            </div>

            <!-- Actions -->
            <div class="acc-cell" style="width:122px;flex:none">
              <div class="acc-actions">
                <a href="/candidate/<%= resumeId %>" class="btn-acc-icon btn-acc-view"
                   title="View Details" onclick="event.stopPropagation()">
                  <i class="fas fa-eye"></i>
                </a>
                <a href="/candidate/<%= resumeId %>/download" class="btn-acc-icon btn-acc-dl"
                   title="Download Resume" target="_blank" onclick="event.stopPropagation()">
                  <i class="fas fa-download"></i>
                </a>
                <button class="btn-acc-toggle" id="toggle-btn-<%= index %>" aria-label="Toggle details">
                  <i class="fas fa-chevron-down"></i>
                </button>
              </div>
            </div>

          </div><!-- /.acc-row-main -->

          <!-- Expandable panel -->
          <div class="acc-panel" id="panel-<%= index %>">
            <div class="acc-panel-inner">

              <!-- Left: contact + all skills -->
              <div class="panel-left">
                <div class="panel-label"><i class="fas fa-id-card me-2"></i>Contact &amp; Profile</div>
                <% if (email) { %>
                <div class="panel-info-row">
                  <i class="fas fa-envelope"></i>
                  <span class="panel-info-val"><%= email %></span>
                </div>
                <% } %>
                <% if (phone) { %>
                <div class="panel-info-row">
                  <i class="fas fa-phone"></i>
                  <span class="panel-info-val"><%= phone %></span>
                </div>
                <% } %>
                <div class="panel-info-row">
                  <i class="fas fa-briefcase"></i>
                  <span class="panel-info-val">
                    <% if (experience > 0) { %><%= experience %> year<%= experience !== 1 ? 's' : '' %> experience
                    <% } else { %>Fresher / No experience listed<% } %>
                  </span>
                </div>

                <% if (skills && skills.length > 0) { %>
                <div class="panel-label mt-3"><i class="fas fa-code me-2"></i>All Skills (<%= skills.length %>)</div>
                <div class="panel-skills-all">
                  <% skills.forEach(function(sk){ %><span class="skill-chip"><%= sk %></span><% }); %>
                </div>
                <% } %>
              </div><!-- /.panel-left -->

              <!-- Right: job score bars -->
              <div class="panel-right">
                <div class="panel-label"><i class="fas fa-chart-bar me-2"></i>All Job Match Scores</div>
                <% if (candidate.allJobScores && Object.keys(candidate.allJobScores).length > 0) {
                  var jsa = [];
                  for (var jk in candidate.allJobScores) {
                    if (candidate.allJobScores.hasOwnProperty(jk)) {
                      var jd = candidate.allJobScores[jk];
                      jsa.push({ title: jd.jobTitle || jk, score: jd.matchScore || jd.score || 0 });
                    }
                  }
                  jsa.sort(function(a,b){ return b.score - a.score; });
                %>
                <% jsa.forEach(function(jb, ji){ %>
                <%
                  var barClr = jb.score >= 75 ? '#10b981' : jb.score >= 50 ? '#f59e0b' : '#ef4444';
                  var pbCls  = jb.score >= 75 ? 'score-high' : jb.score >= 50 ? 'score-mid' : 'score-low';
                %>
                <div class="panel-job-bar">
                  <div class="panel-bar-header">
                    <div class="panel-bar-title">
                      <span class="panel-bar-idx"><%= ji + 1 %></span>
                      <%= jb.title.replace(/[_]/g,' ').replace(/\b\w/g,function(l){return l.toUpperCase();}) %>
                      <% if (ji === 0) { %><span class="tag-best-match">Best</span><% } %>
                    </div>
                    <span class="score-pill score-pill-sm <%= pbCls %>"><%= Math.round(jb.score) %>%</span>
                  </div>
                  <div class="panel-track">
                    <div class="panel-fill" data-width="<%= jb.score %>" data-color="<%= barClr %>"></div>
                  </div>
                </div>
                <% }); %>
                <% } else { %>
                <p class="text-muted small">No detailed scores stored for this candidate.</p>
                <% } %>
              </div><!-- /.panel-right -->

            </div><!-- /.acc-panel-inner -->
          </div><!-- /.acc-panel -->

        </div><!-- /.acc-row -->
        <% }); %>
      </div><!-- /#candidatesContainer -->

      <!-- Pagination Controls -->
      <% if (pagination && pagination.totalPages > 1) { %>
      <div class="row mb-4">
        <div class="col-12">
          <nav aria-label="Candidate results pagination">
            <ul class="pagination justify-content-center pagination-lg">
              <!-- Previous Page Button -->
              <% if (pagination.hasPrevPage) { %>
              <li class="page-item">
                <a class="page-link bg-dark text-light border-secondary" href="?search=<%= searchQuery || '' %>&page=<%= pagination.prevPage %>&limit=<%= pagination.limit %>">
                  <i class="fas fa-chevron-left me-1"></i> Previous
                </a>
              </li>
              <% } else { %>
              <li class="page-item disabled">
                <span class="page-link bg-dark text-muted border-secondary">
                  <i class="fas fa-chevron-left me-1"></i> Previous
                </span>
              </li>
              <% } %>

              <!-- Page Numbers -->
              <% 
              var startPage = Math.max(1, pagination.page - 2);
              var endPage = Math.min(pagination.totalPages, pagination.page + 2);
              
              if (startPage > 1) {
              %>
              <li class="page-item">
                <a class="page-link bg-dark text-light border-secondary" href="?search=<%= searchQuery || '' %>&page=1&limit=<%= pagination.limit %>">1</a>
              </li>
              <% if (startPage > 2) { %>
              <li class="page-item disabled">
                <span class="page-link bg-dark text-muted border-secondary">...</span>
              </li>
              <% } %>
              <% } %>
              
              <% for (var i = startPage; i <= endPage; i++) { %>
                <% if (i === pagination.page) { %>
                <li class="page-item active">
                  <span class="page-link bg-primary border-primary"><%= i %></span>
                </li>
                <% } else { %>
                <li class="page-item">
                  <a class="page-link bg-dark text-light border-secondary" href="?search=<%= searchQuery || '' %>&page=<%= i %>&limit=<%= pagination.limit %>"><%= i %></a>
                </li>
                <% } %>
              <% } %>
              
              <% if (endPage < pagination.totalPages) { %>
                <% if (endPage < pagination.totalPages - 1) { %>
                <li class="page-item disabled">
                  <span class="page-link bg-dark text-muted border-secondary">...</span>
                </li>
                <% } %>
              <li class="page-item">
                <a class="page-link bg-dark text-light border-secondary" href="?search=<%= searchQuery || '' %>&page=<%= pagination.totalPages %>&limit=<%= pagination.limit %>"><%= pagination.totalPages %></a>
              </li>
              <% } %>

              <!-- Next Page Button -->
              <% if (pagination.hasNextPage) { %>
              <li class="page-item">
                <a class="page-link bg-dark text-light border-secondary" href="?search=<%= searchQuery || '' %>&page=<%= pagination.nextPage %>&limit=<%= pagination.limit %>">
                  Next <i class="fas fa-chevron-right ms-1"></i>
                </a>
              </li>
              <% } else { %>
              <li class="page-item disabled">
                <span class="page-link bg-dark text-muted border-secondary">
                  Next <i class="fas fa-chevron-right ms-1"></i>
                </span>
              </li>
              <% } %>
            </ul>
          </nav>
          
          <!-- Pagination Info -->
          <div class="text-center text-light mt-3">
            <small>
              Showing <strong><%= pagination.startIndex %></strong> to <strong><%= pagination.endIndex %></strong> of <strong><%= pagination.totalCount %></strong> results
              (Page <strong><%= pagination.page %></strong> of <strong><%= pagination.totalPages %></strong>)
            </small>
          </div>
        </div>
      </div>
      <% } %>
    </div>
  </div>
  <% } else { %>
  <!-- No Results -->
  <div class="row">
    <div class="col-12">
      <div class="text-center py-5">
        <div class="card border-0 shadow-lg multi-no-results">
          <div class="card-body py-5">
            <i class="fas fa-search fa-4x text-muted mb-4"></i>
            <h3 class="text-white mb-3">
              No candidates were processed in this multi-JD screening session
            </h3>
            <p class="text-light mb-4">
              Try adjusting your screening criteria or upload more resumes to
              get better results.
            </p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
              <a href="/screening" class="btn btn-primary btn-lg">
                <i class="fas fa-cog"></i> Start New Screening
              </a>
              <a href="/upload" class="btn btn-outline-light btn-lg">
                <i class="fas fa-upload"></i> Upload More Resumes
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% } %>
</div>

<script>
  // ── Accordion row toggle ──────────────────────────────────────────────────
  function toggleAccRow(idx) {
    var panel = document.getElementById('panel-' + idx);
    var btn   = document.getElementById('toggle-btn-' + idx);
    var row   = document.getElementById('row-' + idx);
    if (!panel) return;
    var isOpen = panel.classList.contains('open');

    // Close any currently open panel
    document.querySelectorAll('.acc-panel.open').forEach(function (p) { p.classList.remove('open'); });
    document.querySelectorAll('.btn-acc-toggle.open').forEach(function (b) { b.classList.remove('open'); });
    document.querySelectorAll('.acc-row.row-open').forEach(function (r) { r.classList.remove('row-open'); });

    if (!isOpen) {
      panel.classList.add('open');
      btn.classList.add('open');
      row.classList.add('row-open');

      // Animate fills after panel is visible
      setTimeout(function () {
        panel.querySelectorAll('.panel-fill').forEach(function (f) {
          var target = f.getAttribute('data-width') || '0';
          var color  = f.getAttribute('data-color') || '#6b7280';
          f.style.width = target + '%';
          f.style.background = color;
        });
      }, 60);
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    // Apply avatar gradients from data-grad attributes
    document.querySelectorAll('.cand-avatar[data-grad]').forEach(function (el) {
      el.style.background = el.getAttribute('data-grad');
    });
    var scoreSlider    = document.getElementById('minMatchScore');
    var scoreDisplay   = document.getElementById('scoreDisplay');
    var sortSelect     = document.getElementById('sortResults');
    var categoryFilter = document.getElementById('categoryFilter');
    var visibleCountSpan = document.getElementById('visibleCount');

    // Score slider
    if (scoreSlider) {
      scoreSlider.addEventListener('input', function () {
        if (scoreDisplay) scoreDisplay.textContent = this.value;
        filterCandidates();
      });
    }
    // Category filter
    if (categoryFilter) { categoryFilter.addEventListener('change', filterCandidates); }
    // Sort
    if (sortSelect) { sortSelect.addEventListener('change', function () { sortCandidates(this.value); }); }

    function getRows() { return document.querySelectorAll('.candidate-result-card'); }

    function filterCandidates() {
      var minScore = scoreSlider ? parseInt(scoreSlider.value) : 0;
      var selCat   = categoryFilter ? categoryFilter.value : '';
      var visible  = 0;
      getRows().forEach(function (row) {
        var sc  = parseInt(row.dataset.score || 0);
        var cat = row.dataset.category || '';
        var show = sc >= minScore && (!selCat || cat.indexOf(selCat.toLowerCase()) !== -1);
        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (visibleCountSpan) visibleCountSpan.textContent = visible;
    }

    function sortCandidates(type) {
      var container = document.getElementById('candidatesContainer');
      var rows = Array.from(container.querySelectorAll('.acc-row'));
      rows.sort(function (a, b) {
        switch (type) {
          case 'score-desc': return (+b.dataset.score || 0) - (+a.dataset.score || 0);
          case 'score-asc':  return (+a.dataset.score || 0) - (+b.dataset.score || 0);
          case 'name-asc':   return (a.dataset.name || '').localeCompare(b.dataset.name || '');
          case 'name-desc':  return (b.dataset.name || '').localeCompare(a.dataset.name || '');
          case 'category':
            var ca = a.dataset.category || 'zzz', cb = b.dataset.category || 'zzz';
            if (ca !== cb) return ca.localeCompare(cb);
            return (+b.dataset.score || 0) - (+a.dataset.score || 0);
          default: return 0;
        }
      });
      rows.forEach(function (r) { container.appendChild(r); });
    }

    // Excel download feedback
    var excelBtn = document.getElementById('exportButton');
    if (excelBtn) {
      excelBtn.addEventListener('click', function () {
        var orig = this.innerHTML;
        this.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Generating Excel...<small class="d-block mt-1">Please wait...</small>';
        this.style.opacity = '0.8'; this.style.pointerEvents = 'none';
        setTimeout(function () {
          if (excelBtn) { excelBtn.innerHTML = orig; excelBtn.style.opacity = '1'; excelBtn.style.pointerEvents = 'auto'; }
        }, 2500);
      });
    }

    filterCandidates();
  });
</script>

